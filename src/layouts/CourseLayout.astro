        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 1rem;
        padding: 1.15rem 1.3rem;
        border-radius: 999px;
        background: #000000;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 16px 32px rgba(18, 20, 22, 0.14);
      }

      .key-considerations-tip-icon {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 999px;
        display: grid;
        place-items: center;
        color: var(--lime);
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.03);
        flex-shrink: 0;
      }

      .key-considerations-tip-text {
        margin: 0;
        min-width: 0;
        color: #ffffff;
        line-height: 1.6;
        text-align: left;
      }

      .key-considerations-tip-text em {
        font-style: italic;
      }

      .key-considerations-question {
        margin-top: var(--block-space);
      }

      .steps-grid {
        display: grid;
        gap: 1.4rem;
      }

      .steps-grid-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .steps-grid-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .step-card {
        box-shadow: var(--shadow-soft);
      }

      .step-number {
        display: flex;
        height: 3rem;
        width: 3rem;
        flex-shrink: 0;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid rgba(18, 20, 22, 0.08);
        background: var(--surface-soft);
        color: var(--text);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0.12em;
      }

      .wrap-card {
        justify-content: center;
