        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
        align-items: center;
        gap: 1rem 1.5rem;
        padding: 0.7rem 0.75rem 0.7rem 1.5rem;
        border-radius: 999px;
        background: var(--lime);
        border: 0;
        box-shadow: 0 14px 28px rgba(18, 20, 22, 0.12);
      }

      .course-footer-spacer {
        min-height: 1px;
      }

      .course-footer-message {
        margin: 0;
        color: #000000;
        font-size: clamp(0.95rem, 1.4vw, 1.05rem);
        line-height: 1.5;
        text-align: center;
        justify-self: center;
      }

      .course-footer-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        min-height: 44px;
        padding: 0.8rem 1.2rem;
        border-radius: 999px;
        text-decoration: none;
        color: #000000;
        font-size: 0.98rem;
        font-weight: 700;
        background: #a8ca1a;
        border: 0;
        justify-self: end;
        transition: background 0.2s ease, transform 0.2s ease;
