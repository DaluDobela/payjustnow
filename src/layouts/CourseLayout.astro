---
import "../styles/global.css";

interface Props {
  title?: string;
  pdfMode?: boolean;
  showPageDecor?: boolean;
  showBackToTop?: boolean;
}

const {
  title = "PayJustNow Quick Course",
  pdfMode = false,
  showPageDecor = !pdfMode,
  showBackToTop = !pdfMode,
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <style is:global>
      :root {
        --bg: #ffffff;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-strong: #ffffff;
        --surface-soft: #fbf7ef;
        --text: #121416;
        --muted: #5d625d;
        --line: rgba(18, 20, 22, 0.12);

        --charcoal: #343b42;
        --charcoal-strong: #2a3137;
        --nav-pill: #555d66;
        --lime: #d6ff00;
        --lime-soft: rgba(214, 255, 0, 0.14);
        --accent: #121416;
        --accent-soft: rgba(18, 20, 22, 0.08);

        --shadow: 0 22px 44px rgba(18, 20, 22, 0.08);
        --shadow-soft: 0 14px 30px rgba(18, 20, 22, 0.06);
        --radius: 30px;
        --max: 1200px;

        --font-body: "Segoe UI Variable", "Segoe UI", "Helvetica Neue", Arial, sans-serif;
        --font-display: "Arial Black", "Segoe UI", "Helvetica Neue", Arial, sans-serif;

        --type-hero: clamp(3rem, 7vw, 5.5rem);
        --type-title: clamp(2rem, 4vw, 3rem);
        --type-product: 1.6rem;
        --leading-product: 1.25;
        --type-body: clamp(1rem, 1.2vw, 1.125rem);
        --type-ui: 0.92rem;
        --type-label: 12px;
        --block-space: clamp(3rem, 5vw, 4.5rem);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: var(--font-body);
        font-size: var(--type-body);
        line-height: 1.75;
        color: var(--text);
        position: relative;
        overflow-x: hidden;
        background: #ffffff;
      }

      body.pdf-layout {
        background: #ffffff;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      .container {
        width: min(var(--max), calc(100% - 2rem));
        margin: 0 auto;
      }

      .course-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        padding-top: 0.75rem;
      }

      .course-nav-inner {
        min-height: 76px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 1rem;
        position: relative;
        padding: 0.75rem 1rem;
        border-radius: 999px;
        background: #000000;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 20px 38px rgba(18, 20, 22, 0.14);
      }

      .course-nav-brand {
        text-decoration: none;
        color: #ffffff;
        font-weight: 700;
        letter-spacing: -0.02em;
        font-size: 1.2rem;
        max-width: 100%;
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        min-width: 0;
      }

      .course-nav-mark {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.95rem;
        background: var(--lime);
        display: grid;
        place-items: center;
        flex-shrink: 0;
        box-shadow: inset 0 0 0 1px rgba(18, 20, 22, 0.08);
      }

      .course-nav-mark-image {
        width: 1.8rem;
        height: 1.8rem;
        object-fit: contain;
        display: block;
      }

      .course-nav-brand-text {
        white-space: nowrap;
      }

      .course-nav-toggle {
        display: none;
        width: 48px;
        height: 48px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.06);
        cursor: pointer;
        padding: 0;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
      }

      .course-nav-toggle span {
        display: block;
        width: 18px;
        height: 2px;
        background: #ffffff;
        border-radius: 999px;
      }

      .course-nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        align-items: center;
        justify-content: flex-end;
      }

      .course-nav-links a {
        text-decoration: none;
        color: rgba(255, 255, 255, 0.92);
        font-size: var(--type-ui);
        font-weight: 700;
        padding: 0.8rem 1rem;
        border-radius: 999px;
        background: transparent;
        border: 1px solid transparent;
        transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease, border-color 0.25s ease;
      }

      .course-nav-links a:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        transform: translateY(-1px);
      }

      .course-nav-links a.active {
        background: var(--nav-pill);
        color: #ffffff;
        border-color: rgba(255, 255, 255, 0.06);
      }

      @media (max-width: 900px) {
        .course-nav-inner {
          grid-template-columns: minmax(0, 1fr) auto;
          min-height: 72px;
          padding: 0.75rem 0.9rem;
          border-radius: 2rem;
        }

        .course-nav-toggle {
          display: inline-flex;
        }

        .course-nav-links {
          position: absolute;
          top: calc(100% + 0.6rem);
          right: 0;
          left: 0;
          display: none;
          flex-direction: column;
          align-items: stretch;
          gap: 0.5rem;
          padding: 0.9rem;
          border-radius: 1.5rem;
          background: rgba(52, 59, 66, 0.98);
          border: 1px solid rgba(255, 255, 255, 0.08);
          box-shadow: 0 18px 32px rgba(18, 20, 22, 0.18);
        }

        .course-nav-links.open {
          display: flex;
        }

        .course-nav-links a {
          width: 100%;
          text-align: left;
          justify-content: flex-start;
        }
      }

      .section {
        padding: 5.75rem 0;
        position: relative;
      }

      .section:nth-of-type(even) {
        background: rgba(255, 255, 255, 0.26);
      }

      .section::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 5%;
        width: 90%;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(18, 20, 22, 0.08), transparent);
      }

      .card {
        background: var(--surface-strong);
        backdrop-filter: blur(12px);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      .card-hover {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
      }

      .card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 22px 45px rgba(0, 0, 0, 0.1);
      }

      .section-title {
        font-family: var(--font-display);
        font-size: var(--type-title);
        line-height: 1.06;
        margin: 0 0 0.85rem;
        letter-spacing: -0.03em;
        text-wrap: balance;
      }

      .section-copy {
        color: var(--muted);
        font-size: var(--type-body);
        line-height: 1.8;
        max-width: 720px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        font-size: var(--type-ui);
        font-weight: 700;
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 24px rgba(18, 20, 22, 0.12);
      }

      .hero-pill {
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.08);
      }

      .product-pill {
        background: var(--text);
        color: #ffffff;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .tag {
        display: inline-block;
        padding: 0.4rem 0.75rem;
        border-radius: 999px;
        font-size: var(--type-label);
        font-weight: 700;
        letter-spacing: 0.05em;
        background: #fff;
        border: 1px solid var(--line);
      }

      .tag.hero {
        background: rgba(226, 232, 240, 0.9);
        color: var(--accent);
      }

      .tag.new {
        background: rgba(0, 0, 0, 0.05);
      }

      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.4rem;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
        gap: 1.6rem;
      }

      .divider {
        width: 110px;
        height: 3px;
        background: var(--lime);
        border-radius: 999px;
        margin-top: 1.1rem;
      }

      .lesson-shell {
        max-width: 760px;
      }

      .range-tag-card {
        padding: 0.9rem 1rem;
        font-size: var(--type-body);
        background: rgba(255, 255, 255, 0.32);
        border: 1px solid rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(12px);
      }

      .editorial-kicker {
        display: inline-block;
        font-size: var(--type-label);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.9rem;
      }

      .category-card {
        text-decoration: none;
        color: inherit;
        padding: 0;
        overflow: hidden;
        min-height: 240px;
        background: linear-gradient(to bottom right, rgba(255, 255, 255, 0.95), rgba(247, 244, 239, 0.92));
      }

      .category-card-inner {
        padding: 1.6rem;
        display: flex;
        flex-direction: column;
        height: 100%;
        justify-content: space-between;
      }

      .category-title {
        margin: 0 0 0.75rem;
        font-size: var(--type-title);
        line-height: 1.3;
      }

      .category-copy {
        margin: 0;
        color: var(--muted);
        font-size: var(--type-body);
        line-height: 1.75;
      }

      .category-link {
        margin-top: 1.5rem;
        font-weight: 700;
        font-size: var(--type-ui);
        color: var(--text);
      }

      .category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  padding: 0.7rem 1rem;
  border-radius: 999px;
  background: var(--text);
  color: #ffffff;
  font-size: var(--type-ui);
  font-weight: 700;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
  margin-bottom: 1.2rem;
}

      .product-card {
        overflow: hidden;
        padding: 0;
        background: rgba(255, 255, 255, 0.84);
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      .product-image-wrap {
        background: linear-gradient(to bottom, #f9f7f3, #f1efe9);
        padding: 2rem;
        min-height: 270px;
        display: grid;
        place-items: center;
        border-bottom: 1px solid var(--line);
      }

      .product-image {
        width: 100%;
        max-width: 220px;
        max-height: 220px;
        object-fit: contain;
        display: block;
        filter: drop-shadow(0 14px 24px rgba(15, 23, 42, 0.14));
      }

      .product-content {
        padding: 1.3rem;
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
      }

      .product-top-row {
        display: flex;
        gap: 0.75rem;
        justify-content: space-between;
        align-items: start;
        flex-wrap: wrap;
      }

      .product-title {
        margin: 0;
        font-size: var(--type-product);
        line-height: var(--leading-product);
      }

      .product-description {
        color: var(--muted);
        font-size: var(--type-body);
        line-height: 1.75;
        margin: 0.85rem 0 1.1rem;
      }

      .product-button {
        border: none;
        background: var(--text);
        color: white;
        padding: 0.85rem 1rem;
        border-radius: 999px;
        font-size: var(--type-ui);
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s ease;
        align-self: flex-start;
      }

      .product-button:hover {
        background: var(--text);
        transform: translateY(-2px);
        opacity: 0.94;
      }

      .product-details {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s ease, margin-top 0.3s ease;
        margin-top: 0;
      }

      .product-card.open .product-details {
        max-height: 320px;
        overflow-y: auto;
        margin-top: 1rem;
      }

      .product-details::-webkit-scrollbar {
        width: 6px;
      }

      .product-details::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.18);
        border-radius: 999px;
      }

      .product-list {
        padding-left: 1.2rem;
        color: var(--muted);
        font-size: var(--type-body);
        line-height: 1.85;
        margin: 0;
      }

      .product-benefits-list {
        margin-top: 0;
      }

      .tip-box {
        padding: 1rem;
        border-radius: 18px;
        background: rgba(27, 31, 34, 0.06);
        margin-top: 1.25rem;
      }

      .recommend-box {
        margin-top: 1.25rem;
      }

      .product-recommend-list {
        margin-top: 0.75rem;
      }

      .scenario-option {
        text-align: left;
        padding: 1rem 1.2rem;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: #fff;
        cursor: pointer;
        font-size: var(--type-body);
        transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
      }

      .scenario-option:hover {
        transform: translateY(-1px);
      }

      .scenario-option:focus-visible {
        outline: 3px solid rgba(214, 255, 0, 0.55);
        outline-offset: 2px;
      }

      .payment-plans-intro {
        max-width: 50rem;
        margin: 0 auto;
        text-align: center;
      }

      .basics-payment-intro {
        margin-top: calc(1.5rem + 20px);
      }

      .basics-payment-transition {
        margin-top: 40px;
      }

      .basics-question-block {
        width: 100%;
        margin-block: var(--block-space);
      }

      .payment-plans-shell {
        width: 100%;
        display: grid;
        gap: 1.75rem;
      }

      .payment-plans-header {
        max-width: 44rem;
        margin: 0 auto;
        text-align: center;
      }

      .payment-plans-title {
        margin-bottom: 0;
        font-size: clamp(1.95rem, 3.4vw, 2.8rem);
      }

      .payment-plans-intro-copy {
        margin: 0;
        color: var(--muted);
        font-size: var(--type-body);
        line-height: 1.8;
      }

      .basics-payment-transition-copy {
        font-weight: 700;
      }

      .payment-plans-copy {
        max-width: 54rem;
        margin: 0 auto;
        display: grid;
        gap: 1rem;
      }

      .payment-plans-copy-paragraph {
        margin: 0;
        color: var(--muted);
        font-size: var(--type-body);
        line-height: 1.8;
        text-align: center;
      }

      .payment-plans-copy-accent {
        width: 5.5rem;
        height: 0.25rem;
        margin: 0.2rem auto 0;
        border-radius: 999px;
        background: var(--lime);
        display: block;
      }

      .payment-plans-video-block {
        max-width: 60rem;
        margin: 0 auto;
      }

      .payment-plans-media {
        width: 100%;
        max-width: 68rem;
        margin: 2rem auto 0;
      }

      .payment-plans-subtitle {
        margin: 0 0 1rem;
        color: var(--text);
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2.2vw, 1.7rem);
        line-height: 1.15;
        text-align: center;
      }

      .payment-plans-tip {
        width: min(100%, 860px);
        margin: var(--block-space) auto 0;
      }

      .payment-plans-tip-text {
        display: block;
      }

      .payment-plans-tip-label {
        display: inline;
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-right: 0.35rem;
      }

      .scenario-card-embedded {
        padding: clamp(1.35rem, 3vw, 2rem);
        background: #e1e5e7;
        border: 1px solid rgba(18, 20, 22, 0.1);
        box-shadow: 0 18px 30px rgba(18, 20, 22, 0.28);
      }

      .scenario-card-embedded > .grid:first-child {
        display: none;
      }

      .scenario-card-embedded > .mt-8 {
        margin-top: 0;
      }

      .scenario-card-embedded .scenario-question {
        display: block;
      }

      .scenario-question-card {
        background: #ffffff;
        border: 1px solid rgba(18, 20, 22, 0.08);
        box-shadow: none;
      }

      .scenario-question-text {
        margin: 0;
        color: var(--text);
        font-size: clamp(1.2rem, 2.1vw, 1.55rem);
        line-height: 1.15;
        font-weight: 800;
        white-space: pre-line;
      }

      .scenario-option-embedded {
        align-items: flex-start;
        padding: 1rem 1.1rem;
        min-height: 44px;
        box-shadow: none;
      }

      .scenario-option-badge {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(18, 20, 22, 0.14);
        background: rgba(18, 20, 22, 0.03);
        font-size: 0.95rem;
        line-height: 1;
        margin-top: 0.05rem;
      }

      .scenario-option-embedded[data-selected="true"] .scenario-option-badge {
        border-color: rgba(18, 20, 22, 0.24);
      }

      .scenario-option-embedded[data-state="correct"] .scenario-option-badge {
        background: rgba(214, 255, 0, 0.28);
        border-color: rgba(132, 204, 22, 0.4);
      }

      .scenario-option-embedded[data-state="incorrect"] .scenario-option-badge {
        background: rgba(18, 20, 22, 0.06);
        border-color: rgba(18, 20, 22, 0.14);
      }

      .scenario-feedback-panel {
        margin-top: 1rem;
        border: 1px solid rgba(18, 20, 22, 0.08);
        box-shadow: none;
      }

      .scenario-feedback-panel[hidden] {
        display: none !important;
      }

      .hero-section {
        position: relative;
        overflow: visible;
      }

      .hero-section::after {
        display: none;
      }

      .hero-section-main {
        padding-top: clamp(1.25rem, 2.5vw, 1.9rem);
        padding-bottom: clamp(3.5rem, 5vw, 4.75rem);
      }

      .hero-shell {
        position: relative;
        overflow: hidden;
        width: 100%;
        border-radius: clamp(2rem, 3vw, 2.8rem);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 28px 52px rgba(18, 20, 22, 0.18);
      }

      .hero-bg {
        position: absolute;
        inset: 0;
        background: #000000;
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        background: transparent;
      }

      .page-decor {
        display: none;
      }

      .hero-inner {
        position: relative;
        z-index: 1;
        padding: clamp(2rem, 4vw, 3.4rem);
      }

      .hero-main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(250px, 0.8fr);
        gap: clamp(1.75rem, 3vw, 3.2rem);
        align-items: center;
      }

      .hero-copy {
        padding-right: clamp(0rem, 1.5vw, 0.75rem);
        min-width: 0;
      }

      .hero-main-title {
        margin: 0 0 1rem;
        max-width: 10ch;
        color: #ffffff;
        font-size: clamp(3rem, 5.2vw, 4.85rem);
        line-height: 0.98;
      }

      .hero-main-subtitle {
        margin: 0;
        max-width: 620px;
        color: rgba(255, 255, 255, 0.9);
        font-size: var(--type-body);
        line-height: 1.65;
      }

      .hero-main-points {
        padding-left: 1.2rem;
        color: rgba(255, 255, 255, 0.92);
        font-size: var(--type-body);
        line-height: 1.75;
        margin: 1.15rem 0 0;
        display: grid;
        gap: 0.9rem;
        max-width: 42rem;
      }

      .hero-main-points li::marker {
        color: rgba(214, 255, 0, 0.92);
      }

      .hero-logo-panel {
        justify-self: end;
        width: min(100%, 380px);
        aspect-ratio: 1 / 1;
        display: grid;
        place-items: center;
        padding: 0;
      }

      .hero-logo-frame {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: clamp(2rem, 3vw, 2.5rem);
        display: block;
        overflow: hidden;
      }

      .hero-logo-core {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: inherit;
        background: transparent;
        display: block;
        overflow: hidden;
      }

      .hero-logo-image {
        width: 100%;
        height: 100%;
        max-width: none;
        object-fit: cover;
        display: block;
        filter: none;
      }

      .hero-product-card {
        overflow: hidden;
        padding: 0;
      }

      .hero-product-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        align-items: stretch;
      }

      .hero-product-image-wrap {
        background: linear-gradient(to bottom, #f9f7f3, #efede8);
        padding: 2rem;
        min-height: 420px;
        display: grid;
        place-items: center;
      }

      .hero-product-image {
        width: 100%;
        max-width: 320px;
        max-height: 320px;
        object-fit: contain;
        display: block;
        filter: drop-shadow(0 18px 30px rgba(15, 23, 42, 0.14));
      }

      .hero-product-content {
        padding: 2rem;
        min-width: 0;
      }

      .hero-product-top {
        display: flex;
        gap: 0.6rem;
        align-items: center;
        margin-bottom: 0.9rem;
        flex-wrap: wrap;
      }

      .hero-product-title {
        margin: 0 0 0.8rem;
        font-size: var(--type-product);
