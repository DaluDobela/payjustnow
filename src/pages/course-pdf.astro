---
import CourseLayout from "../layouts/CourseLayout.astro";
import { courseData } from "../data/payjustnow-course";
---

<CourseLayout
  title={`${courseData.meta.title} | PDF Placeholder`}
  pdfMode={true}
  showPageDecor={false}
  showBackToTop={false}
>
  <section class="section">
    <div class="container">
      <article class="card content-card">
        <span class="content-card-kicker">Phase 1</span>
        <h1 class="section-title">PDF export will be rebuilt in a later phase</h1>
        <p class="section-copy max-w-3xl">
          The live course content has been updated to the PayJustNow structure.
          The printable export route is intentionally deferred until the main
          learning experience and interactions are approved.
        </p>
      </article>
    </div>
  </section>
</CourseLayout>
