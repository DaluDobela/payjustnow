---
interface Props {
  question: string;
  options: string[];
  correctIndex: number;
  feedback: string;
}

const { question, options, correctIndex, feedback } = Astro.props;
---

<section class="section" id="scenario-activity">
  <div class="container">
    <div class="activity-shell">
      <div class="card" style="padding:2rem; background:rgba(255,255,255,0.9);">
        <span class="editorial-kicker">Lesson 7</span>
        <h2 class="section-title" style="margin-top:0;">Selling Activity</h2>
        <p class="section-copy">{question}</p>

        <div style="display:grid; gap:1rem; margin-top:1.75rem;">
          {options.map((option, i) => (
            <button
              type="button"
              class="scenario-option"
              onclick={`const feedback = document.getElementById('scenario-feedback');
                const buttons = document.querySelectorAll('.scenario-option');
                buttons.forEach((btn) => {
                  btn.style.borderColor = 'var(--line)';
                  btn.style.background = '#fff';
                });
                if (${i} === ${correctIndex}) {
                  this.style.borderColor = 'var(--accent)';
                  this.style.background = 'var(--accent-soft)';
                  feedback.innerHTML = '<strong>Correct.</strong> ${feedback}';
                } else {
                  this.style.borderColor = '#c98b8b';
                  this.style.background = 'rgba(201, 139, 139, 0.12)';
                  feedback.innerHTML = '<strong>Not quite.</strong> Think about which option best matches the customer need and creates more value.';
                }`}
            >
              <span style="font-weight:700; margin-right:0.4rem;">{String.fromCharCode(65 + i)}.</span>
              {option}
            </button>
          ))}
        </div>

        <div
          id="scenario-feedback"
          class="card"
          style="padding:1rem; margin-top:1.5rem; background:var(--surface-strong); min-height:72px;"
        >
          Choose an answer to see feedback.
        </div>
      </div>
    </div>
  </div>
</section>