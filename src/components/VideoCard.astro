---
interface Props {
  title: string;
  embedUrl: string;
  frame?: "default" | "laptop";
  showHeader?: boolean;
}

const {
  title,
  embedUrl,
  frame = "default",
  showHeader = true,
} = Astro.props as Props;
---

<div class:list={["card video-card", frame === "laptop" && "video-card-laptop"]}>
  {showHeader && (
    <div class="video-card-header">
      <h3>{title}</h3>
    </div>
  )}

  {frame === "laptop" ? (
    <div class="laptop-shell" aria-hidden="true">
      <div class="laptop-screen">
        <div class="video-frame video-frame-laptop">
          <iframe
            src={embedUrl}
            title={title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>
      </div>
      <div class="laptop-base"></div>
    </div>
  ) : (
    <div class="video-frame">
      <iframe
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
  )}
</div>
