---
import type { Product } from "../data/brabantia-course";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div class="card card-hover hero-product-card">
  <div class="hero-product-grid">
    <div
      class="hero-product-image-wrap relative isolate w-full overflow-hidden"
      style="background:#edf4fb;"
    >
      <div
        class="absolute inset-0"
        style="background:linear-gradient(180deg, #edf4fb 0%, #eef4fb 68%, #f7f9fc 100%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute inset-x-0 bottom-0 h-[32%]"
        style="background:linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.55) 100%);"
        aria-hidden="true"
      ></div>
      <div class="relative z-10 flex h-full w-full items-center justify-center">
        <div
          class="absolute bottom-[18%] left-1/2 h-12 w-44 -translate-x-1/2 rounded-full blur-2xl"
          style="background:rgba(148,163,184,0.18);"
          aria-hidden="true"
        ></div>
        <img
          src={product.image}
          alt={product.name}
          class="hero-product-image relative z-10 h-auto"
        />
      </div>
    </div>

    <div class="hero-product-content flex h-full flex-col justify-center">
      <div class="hero-product-top justify-start">
        {product.tag && (
          <span class={`tag ${product.tag === "HERO" ? "hero" : "new"}`}>
            {product.tag}
          </span>
        )}
        <span class="pill product-pill">Featured Product</span>
      </div>

      <h3 class="hero-product-title">{product.name}</h3>
      <p class="hero-product-description">{product.description}</p>

      <ul class="product-list product-benefits-list">
        {product.benefits.map((benefit) => <li>{benefit}</li>)}
      </ul>

      <div class="tip-box w-full">
        <strong>Selling Tip:</strong> {product.sellingTip}
      </div>

      <div class="recommend-box w-full">
        <strong>When to recommend:</strong>
        <ul class="product-list product-recommend-list">
          {product.recommendWhen.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</div>
