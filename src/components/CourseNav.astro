---
interface NavSection {
  id: string;
  label: string;
}

interface Props {
  brandName: string;
  logoSrc: string;
  sections: NavSection[];
}

const { brandName, logoSrc, sections } = Astro.props as Props;
---

<nav class="course-nav" data-course-nav>
  <div class="container course-nav-inner">
    <a href="#top" class="course-nav-brand">
      <span class="course-nav-mark" aria-hidden="true">
        <img src={logoSrc} alt="" class="course-nav-mark-image" />
      </span>
      <span class="course-nav-brand-text">{brandName}</span>
    </a>

    <button
      class="course-nav-toggle shrink-0"
      type="button"
      aria-expanded="false"
      aria-controls="course-nav-menu"
      onclick="
        const menu = document.getElementById('course-nav-menu');
        const expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!expanded));
        menu.classList.toggle('open', !expanded);
      "
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div id="course-nav-menu" class="course-nav-links w-full md:w-auto">
      {sections.map((section, index) => (
        <a
          href={`#${section.id}`}
          class="whitespace-nowrap"
          data-nav-link
          data-target-id={section.id}
          aria-current={index === 0 ? "true" : "false"}
        >
          {section.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script is:inline>
  const navRoots = document.querySelectorAll("[data-course-nav]");

  for (const navRoot of navRoots) {
    if (navRoot.dataset.initialized === "true") continue;
    navRoot.dataset.initialized = "true";

    const toggle = navRoot.querySelector(".course-nav-toggle");
    const menu = navRoot.querySelector("#course-nav-menu");
    const links = Array.from(navRoot.querySelectorAll("[data-nav-link]"));
    const sections = links
      .map((link) => document.getElementById(link.dataset.targetId || ""))
      .filter(Boolean);

    const closeMenu = () => {
      if (!menu || !toggle) return;
      menu.classList.remove("open");
      toggle.setAttribute("aria-expanded", "false");
    };

    const setActiveLink = (targetId) => {
      links.forEach((link) => {
        const isActive = link.dataset.targetId === targetId;
        link.classList.toggle("active", isActive);
        link.setAttribute("aria-current", String(isActive));
      });
    };

    links.forEach((link) => {
      link.addEventListener("click", () => {
        setActiveLink(link.dataset.targetId || "");
        if (window.innerWidth <= 900) {
          closeMenu();
        }
      });
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 900) {
        closeMenu();
      }
    });

    if (sections.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (visibleEntry?.target?.id) {
            setActiveLink(visibleEntry.target.id);
          }
        },
        {
          rootMargin: "-30% 0px -45% 0px",
          threshold: [0.2, 0.4, 0.6],
        },
      );

      sections.forEach((section) => observer.observe(section));
      setActiveLink(sections[0].id);
    }
  }
</script>
