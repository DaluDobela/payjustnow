<nav class="course-nav" data-course-nav>
  <div class="container course-nav-inner">
    <a href="#top" class="course-nav-brand block truncate">Brabantia</a>

    <button
      class="course-nav-toggle shrink-0"
      type="button"
      aria-expanded="false"
      aria-controls="course-nav-menu"
      onclick="
        const menu = document.getElementById('course-nav-menu');
        const expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', String(!expanded));
        menu.classList.toggle('open', !expanded);
      "
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div id="course-nav-menu" class="course-nav-links w-full md:w-auto">
      <a href="#range-overview" class="whitespace-nowrap">Range</a>
      <a href="#kitchen-appliances" class="whitespace-nowrap">Kitchen</a>
      <a href="#garment-care" class="whitespace-nowrap">Garment Care</a>
      <a href="#home-solutions" class="whitespace-nowrap">Home Solutions</a>
      <a href="#selling-method" class="whitespace-nowrap">How to Sell</a>
      <a href="#scenario-activity" class="whitespace-nowrap">Activity</a>
    </div>
  </div>
</nav>

<script is:inline>
  const navRoots = document.querySelectorAll("[data-course-nav]");

  for (const navRoot of navRoots) {
    if (navRoot.dataset.initialized === "true") continue;
    navRoot.dataset.initialized = "true";

    const toggle = navRoot.querySelector(".course-nav-toggle");
    const menu = navRoot.querySelector("#course-nav-menu");
    const links = navRoot.querySelectorAll("a[href^='#']");

    const closeMenu = () => {
      if (!menu || !toggle) return;
      menu.classList.remove("open");
      toggle.setAttribute("aria-expanded", "false");
    };

    links.forEach((link) => {
      link.addEventListener("click", () => {
        if (window.innerWidth <= 900) {
          closeMenu();
        }
      });
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 900) {
        closeMenu();
      }
    });
  }
</script>
